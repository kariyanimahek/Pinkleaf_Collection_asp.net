@model Pinkleaf_Collection.Models.User

<link rel="stylesheet" href="~/css/editprofile.css" />

<div class="edit-container">

    <h2>Edit Profile</h2>

    <form method="post">

        <label>Name</label>
        <input asp-for="Name" required />

        <label>Email</label>
        <input asp-for="Email" required />

        <label>Phone</label>
        <input asp-for="Phone" />

        <label>Address</label>
        <textarea asp-for="Address"></textarea>

        <button type="submit" class="save-btn">
            Save Changes
        </button>

    </form>

</div>
